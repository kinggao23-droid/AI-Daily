# AI Daily 凭据配置模板
#
# 用法:
#   cp .ai-daily.env.example ~/.ai-daily.env
#   chmod 600 ~/.ai-daily.env
#   # 然后填入下面的值
#
# ⚠️ 不要把这个文件 commit 到 git! .gitignore 已经忽略了 .env

# ============================================================
# 飞书自定义机器人 webhook URL (必填其一)
#
# 获取方式:
#   1. 飞书 App → 群聊设置 → 群机器人 → 添加机器人
#   2. 选 "自定义机器人"
#   3. 起名 "AI Daily Bot"
#   4. (可选) 启用安全设置 → 选 "签名校验" → 复制下面 secret 同步填写
#   5. 复制 webhook URL 填到 FEISHU_WEBHOOK
# ============================================================
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_KEY"

# (可选) 如果机器人启用了 "签名校验" 安全策略, 填这里
# FEISHU_SECRET="your_secret_string"


# ============================================================
# Bark 推送 URL (必填其二)
#
# 获取方式:
#   1. iPhone App Store 搜 "Bark" → 安装 (开源免费)
#   2. 打开 App, 顶部会显示一个 URL 形如:
#      https://api.day.app/abcdefghijk1234567/
#   3. 复制这个 URL 填到 BARK_URL (末尾的 / 可有可无)
# ============================================================
BARK_URL="https://api.day.app/YOUR_BARK_KEY"
